<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Enviar ubicación al formulario</title>
</head>
<body>
  <h2>Enviando ubicación y hora al formulario...</h2>
  <p id="estado">Espere por favor...</p>

  <script>
    const formURL = "https://docs.google.com/forms/d/e/1FAIpQLSdMcG8CI6IBTo6H8vrzGvb4n79CntQoBPNBUBulh89ZdYCInA/formResponse";
    const entryUbicacion = "entry.1066810132";
    const hora = new Date().toLocaleString();

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(function(position) {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        const ubicacion = `Hora: ${hora} - https://maps.google.com/?q=${lat},${lon}`;

        const form = document.createElement("form");
        form.action = formURL;
        form.method = "POST";
        form.target = "hidden_iframe";

        const input = document.createElement("input");
        input.type = "hidden";
        input.name = entryUbicacion;
        input.value = ubicacion;
        form.appendChild(input);

        const iframe = document.createElement("iframe");
        iframe.name = "hidden_iframe";
        iframe.style.display = "none";
        document.body.appendChild(iframe);

        document.body.appendChild(form);
        form.submit();

        document.getElementById("estado").innerText = "¡Ubicación enviada exitosamente!";
      }, function(error) {
        document.getElementById("estado").innerText = "No se pudo obtener la ubicación: " + error.message;
      });
    } else {
      document.getElementById("estado").innerText = "Tu navegador no permite geolocalización.";
    }
  </script>
</body>
</html>
